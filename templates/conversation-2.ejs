<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%- content.meta.title %></title>
  <meta name="description" content="<%= content.meta.description %>">
  <meta property="og:title" content="<%= content.meta.ogTitle %>">
  <meta property="og:description" content="<%= content.meta.ogDescription %>">
  <meta property="og:type" content="article">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>◆</text></svg>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #FAFAF8;
      --text: #1A1A1A;
      --text-muted: #6B6B6B;
      --accent: #2C2C2C;
      --accent-light: #F0EFED;
      --border: #E5E4E1;
      --highlight: #E8E6E1;
      --quote-bg: #F5F4F1;
      --nav-height: 56px;
      --green: #22c55e;
      --green-light: #f0fdf4;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; scroll-padding-top: var(--nav-height); }
    body {
      font-family: 'Inter', -apple-system, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
    }

    /* --- Nav --- */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      background: rgba(250, 250, 248, 0.85);
      backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid transparent;
      height: var(--nav-height);
      transition: border-color 0.3s, box-shadow 0.3s;
    }
    nav.scrolled { border-bottom-color: var(--border); box-shadow: 0 1px 8px rgba(0,0,0,0.04); }
    .nav-inner {
      max-width: 900px; margin: 0 auto; padding: 0 40px;
      height: 100%; display: flex; align-items: center; justify-content: space-between;
    }
    .nav-logo { font-weight: 700; font-size: 14px; letter-spacing: -0.01em; color: var(--text); text-decoration: none; }
    .nav-logo span { color: var(--text-muted); font-weight: 400; }
    .nav-links { display: flex; align-items: center; gap: 24px; }
    .nav-links a { font-size: 13px; font-weight: 500; color: var(--text-muted); text-decoration: none; transition: color 0.2s; }
    .nav-links a:hover { color: var(--text); }
    .nav-links a.active { color: var(--text); font-weight: 600; }

    /* --- Header --- */
    header {
      max-width: 900px; margin: 0 auto; padding: 120px 40px 60px;
    }
    .meta { font-size: 12px; font-weight: 600; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 20px; }
    header h1 {
      font-family: 'Fraunces', serif; font-size: clamp(2.2rem, 5vw, 3.2rem);
      font-weight: 600; line-height: 1.15; letter-spacing: -0.02em; margin-bottom: 20px;
    }
    header .subtitle { font-size: 1.1rem; color: var(--text-muted); line-height: 1.6; max-width: 640px; margin-bottom: 20px; }
    header .back-link { font-size: 14px; font-weight: 500; color: var(--text-muted); text-decoration: none; transition: color 0.2s; }
    header .back-link:hover { color: var(--text); }

    /* --- Sections --- */
    .content { max-width: 900px; margin: 0 auto; padding: 0 40px; }
    section { padding: 60px 0; border-top: 1px solid var(--border); }
    .section-label {
      font-size: 11px; font-weight: 600; letter-spacing: 0.12em;
      color: var(--text-muted); text-transform: uppercase; margin-bottom: 12px;
    }
    .section-heading {
      font-family: 'Fraunces', serif; font-size: clamp(1.6rem, 3vw, 2rem);
      font-weight: 600; line-height: 1.2; letter-spacing: -0.02em; margin-bottom: 32px;
    }

    /* --- Recap Stats --- */
    .recap-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
    .recap-card {
      background: var(--green-light); border: 1px solid #bbf7d0;
      border-radius: 12px; padding: 24px;
    }
    .recap-card .stat { font-family: 'Fraunces', serif; font-size: 2rem; font-weight: 700; color: #16a34a; margin-bottom: 4px; }
    .recap-card .stat-text { font-size: 14px; color: var(--text-muted); line-height: 1.5; }

    /* --- Theme Cards --- */
    .theme-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
    .theme-card {
      background: white; border: 1px solid var(--border); border-radius: 12px;
      padding: 28px; transition: transform 0.2s, box-shadow 0.2s;
    }
    .theme-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.06); }
    .theme-card .num { font-size: 12px; font-weight: 700; color: var(--text-muted); margin-bottom: 8px; }
    .theme-card h3 { font-family: 'Fraunces', serif; font-size: 1.15rem; font-weight: 600; margin-bottom: 10px; line-height: 1.3; }
    .theme-card p { font-size: 14px; color: var(--text-muted); line-height: 1.6; }

    /* --- Quotes --- */
    .quote-block {
      background: var(--quote-bg); border-left: 3px solid var(--accent);
      padding: 28px 32px; border-radius: 0 12px 12px 0; margin: 40px 0;
    }
    .quote-block blockquote {
      font-family: 'Fraunces', serif; font-size: 1.15rem;
      font-weight: 400; line-height: 1.6; font-style: italic; margin-bottom: 12px;
    }
    .quote-block .attribution { font-size: 13px; color: var(--text-muted); }
    .quote-block .attribution strong { font-weight: 600; color: var(--text); }
    .quote-block .context { font-size: 12px; color: var(--text-muted); margin-top: 4px; font-style: italic; }

    /* --- Live Demo Features --- */
    .demo-description { font-size: 1rem; color: var(--text-muted); line-height: 1.7; max-width: 680px; margin-bottom: 32px; }
    .feature-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
    .feature-card {
      background: #1a1a1a; color: white; border-radius: 12px; padding: 28px;
    }
    .feature-card h3 { font-size: 1rem; font-weight: 600; margin-bottom: 8px; }
    .feature-card p { font-size: 14px; color: #aaa; line-height: 1.6; }

    /* --- Pipeline Steps --- */
    .pipeline-list { display: flex; flex-direction: column; gap: 0; }
    .pipeline-step {
      display: grid; grid-template-columns: 60px 1fr; gap: 20px;
      padding: 28px 0; border-bottom: 1px solid var(--border);
    }
    .pipeline-step:last-child { border-bottom: none; }
    .pipeline-step .step-num {
      font-family: 'Fraunces', serif; font-size: 1.5rem; font-weight: 700;
      color: var(--text-muted); padding-top: 2px;
    }
    .pipeline-step h3 { font-size: 1rem; font-weight: 600; margin-bottom: 6px; }
    .pipeline-step p { font-size: 14px; color: var(--text-muted); line-height: 1.6; }

    /* --- Market Stats --- */
    .market-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 28px; }
    .market-stat {
      text-align: center; padding: 24px 16px;
      background: white; border: 1px solid var(--border); border-radius: 12px;
    }
    .market-stat .val { font-family: 'Fraunces', serif; font-size: 1.8rem; font-weight: 700; margin-bottom: 4px; }
    .market-stat .lbl { font-size: 12px; color: var(--text-muted); line-height: 1.4; }
    .market-insight {
      font-size: 1rem; color: var(--text-muted); line-height: 1.7;
      max-width: 680px; padding: 20px 24px; background: var(--accent-light); border-radius: 10px;
    }

    /* --- WordPress Points --- */
    .wp-points { display: flex; flex-direction: column; gap: 20px; }
    .wp-point { padding: 24px; background: white; border: 1px solid var(--border); border-radius: 12px; }
    .wp-point h3 { font-size: 1rem; font-weight: 600; margin-bottom: 6px; }
    .wp-point p { font-size: 14px; color: var(--text-muted); line-height: 1.6; }

    /* --- Scaling Phases --- */
    .phase-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
    .phase-card {
      background: white; border: 1px solid var(--border); border-radius: 12px;
      padding: 28px; display: flex; flex-direction: column;
    }
    .phase-label {
      font-size: 11px; font-weight: 700; letter-spacing: 0.1em;
      color: var(--green); text-transform: uppercase; margin-bottom: 6px;
    }
    .phase-card h3 { font-family: 'Fraunces', serif; font-size: 1.15rem; font-weight: 600; margin-bottom: 14px; }
    .phase-card ul { list-style: none; display: flex; flex-direction: column; gap: 8px; }
    .phase-card li { font-size: 13px; color: var(--text-muted); line-height: 1.5; padding-left: 16px; position: relative; }
    .phase-card li::before { content: ''; position: absolute; left: 0; top: 8px; width: 6px; height: 6px; border-radius: 50%; background: var(--border); }

    /* --- Ideas --- */
    .ideas-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
    .idea-card {
      background: white; border: 1px solid var(--border); border-radius: 12px;
      padding: 24px; transition: transform 0.2s, box-shadow 0.2s;
    }
    .idea-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.06); }
    .idea-tag {
      display: inline-block; font-size: 10px; font-weight: 700; letter-spacing: 0.08em;
      text-transform: uppercase; padding: 3px 8px; border-radius: 4px;
      background: var(--accent-light); color: var(--text-muted); margin-bottom: 10px;
    }
    .idea-card h3 { font-size: 1rem; font-weight: 600; margin-bottom: 8px; }
    .idea-card p { font-size: 13px; color: var(--text-muted); line-height: 1.6; }

    /* --- Next Steps --- */
    .next-steps-list { display: flex; flex-direction: column; gap: 12px; }
    .next-step {
      display: flex; align-items: flex-start; gap: 12px;
      padding: 14px 18px; background: white; border: 1px solid var(--border); border-radius: 10px;
    }
    .next-step .check { flex-shrink: 0; width: 20px; height: 20px; border: 2px solid var(--border); border-radius: 50%; margin-top: 1px; }
    .next-step span { font-size: 14px; color: var(--text); line-height: 1.5; }

    /* --- Footer --- */
    footer {
      max-width: 900px; margin: 0 auto; padding: 60px 40px;
      border-top: 1px solid var(--border); text-align: center;
    }
    footer p { font-size: 13px; color: var(--text-muted); }
    footer a { color: var(--text); text-decoration: none; font-weight: 500; }
    footer a:hover { text-decoration: underline; }

    /* --- Reveal Animation --- */
    .reveal { opacity: 0; transform: translateY(20px); transition: opacity 0.6s ease, transform 0.6s ease; }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    /* --- Back to Top --- */
    .back-to-top {
      position: fixed; bottom: 32px; right: 32px; width: 40px; height: 40px;
      border-radius: 50%; background: var(--accent); color: white;
      border: none; cursor: pointer; font-size: 18px; display: flex;
      align-items: center; justify-content: center;
      opacity: 0; pointer-events: none; transition: opacity 0.3s;
      box-shadow: 0 2px 12px rgba(0,0,0,0.15);
    }
    .back-to-top.visible { opacity: 1; pointer-events: auto; }

    /* --- Responsive --- */
    @media (max-width: 768px) {
      header, .content { padding-left: 20px; padding-right: 20px; }
      footer { padding-left: 20px; padding-right: 20px; }
      .recap-grid { grid-template-columns: 1fr; }
      .theme-grid { grid-template-columns: 1fr; }
      .feature-grid { grid-template-columns: 1fr; }
      .market-stats { grid-template-columns: repeat(2, 1fr); }
      .phase-grid { grid-template-columns: 1fr; }
      .ideas-grid { grid-template-columns: 1fr; }
      .pipeline-step { grid-template-columns: 40px 1fr; gap: 12px; }
    }
  </style>
</head>
<body>

  <nav>
    <div class="nav-inner">
      <a href="/index.html" class="nav-logo">Workhorse <span>&times; GoDoGood</span></a>
      <div class="nav-links">
        <a href="/index.html">Conversation</a>
        <a href="/conversation-2.html" class="active">Follow-Up</a>
        <a href="/process.html">Full System</a>
      </div>
    </div>
  </nav>

  <header id="top">
    <div class="meta reveal" data-content-path="conversation-2.header.dateline"><%- content.header.dateline %></div>
    <h1 class="reveal" data-content-path="conversation-2.header.title"><%- content.header.title %></h1>
    <p class="subtitle reveal" data-content-path="conversation-2.header.subtitle"><%- content.header.subtitle %></p>
    <a href="<%- content.header.linkHref %>" class="back-link reveal" data-content-path="conversation-2.header.linkText"><%- content.header.linkText %></a>
  </header>

  <div class="content">

    <!-- Recap -->
    <section class="reveal">
      <div class="section-label" data-content-path="conversation-2.recap.label"><%- content.recap.label %></div>
      <h2 class="section-heading" data-content-path="conversation-2.recap.heading"><%- content.recap.heading %></h2>
      <div class="recap-grid">
        <% content.recap.items.forEach(function(item, i) { %>
        <div class="recap-card" data-content-path="conversation-2.recap.items[<%= i %>]">
          <div class="stat"><%- item.stat %></div>
          <div class="stat-text"><%- item.text %></div>
        </div>
        <% }); %>
      </div>
    </section>

    <!-- Themes -->
    <section class="reveal">
      <div class="section-label" data-content-path="conversation-2.themes.label"><%- content.themes.label %></div>
      <h2 class="section-heading" data-content-path="conversation-2.themes.heading"><%- content.themes.heading %></h2>
      <div class="theme-grid">
        <% content.themes.cards.forEach(function(card, i) { %>
        <div class="theme-card" data-content-path="conversation-2.themes.cards[<%= i %>]">
          <div class="num"><%- card.number %></div>
          <h3><%- card.title %></h3>
          <p><%- card.description %></p>
        </div>
        <% }); %>
      </div>
    </section>

    <!-- Quotes -->
    <% content.quotes.forEach(function(q, i) { %>
    <div class="quote-block reveal" data-content-path="conversation-2.quotes[<%= i %>]">
      <blockquote>&ldquo;<%- q.text %>&rdquo;</blockquote>
      <div class="attribution">&mdash; <strong><%- q.author %></strong></div>
      <div class="context"><%- q.context %></div>
    </div>
    <% }); %>

    <!-- Live Demo -->
    <section class="reveal">
      <div class="section-label" data-content-path="conversation-2.liveDemo.label"><%- content.liveDemo.label %></div>
      <h2 class="section-heading" data-content-path="conversation-2.liveDemo.heading"><%- content.liveDemo.heading %></h2>
      <p class="demo-description" data-content-path="conversation-2.liveDemo.description"><%- content.liveDemo.description %></p>
      <div class="feature-grid">
        <% content.liveDemo.features.forEach(function(f, i) { %>
        <div class="feature-card" data-content-path="conversation-2.liveDemo.features[<%= i %>]">
          <h3><%- f.title %></h3>
          <p><%- f.description %></p>
        </div>
        <% }); %>
      </div>
    </section>

    <!-- Pipeline -->
    <section class="reveal">
      <div class="section-label" data-content-path="conversation-2.pipeline.label"><%- content.pipeline.label %></div>
      <h2 class="section-heading" data-content-path="conversation-2.pipeline.heading"><%- content.pipeline.heading %></h2>
      <div class="pipeline-list">
        <% content.pipeline.steps.forEach(function(step, i) { %>
        <div class="pipeline-step" data-content-path="conversation-2.pipeline.steps[<%= i %>]">
          <div class="step-num"><%- step.number %></div>
          <div>
            <h3><%- step.title %></h3>
            <p><%- step.description %></p>
          </div>
        </div>
        <% }); %>
      </div>
    </section>

    <!-- Market -->
    <section class="reveal">
      <div class="section-label" data-content-path="conversation-2.market.label"><%- content.market.label %></div>
      <h2 class="section-heading" data-content-path="conversation-2.market.heading"><%- content.market.heading %></h2>
      <div class="market-stats">
        <% content.market.stats.forEach(function(s, i) { %>
        <div class="market-stat" data-content-path="conversation-2.market.stats[<%= i %>]">
          <div class="val"><%- s.value %></div>
          <div class="lbl"><%- s.label %></div>
        </div>
        <% }); %>
      </div>
      <div class="market-insight" data-content-path="conversation-2.market.insight"><%- content.market.insight %></div>
    </section>

    <!-- WordPress -->
    <section class="reveal">
      <div class="section-label" data-content-path="conversation-2.wordpress.label"><%- content.wordpress.label %></div>
      <h2 class="section-heading" data-content-path="conversation-2.wordpress.heading"><%- content.wordpress.heading %></h2>
      <div class="wp-points">
        <% content.wordpress.points.forEach(function(p, i) { %>
        <div class="wp-point" data-content-path="conversation-2.wordpress.points[<%= i %>]">
          <h3><%- p.title %></h3>
          <p><%- p.description %></p>
        </div>
        <% }); %>
      </div>
    </section>

    <!-- Scaling -->
    <section class="reveal">
      <div class="section-label" data-content-path="conversation-2.scaling.label"><%- content.scaling.label %></div>
      <h2 class="section-heading" data-content-path="conversation-2.scaling.heading"><%- content.scaling.heading %></h2>
      <div class="phase-grid">
        <% content.scaling.phases.forEach(function(ph, i) { %>
        <div class="phase-card" data-content-path="conversation-2.scaling.phases[<%= i %>]">
          <div class="phase-label"><%- ph.phase %></div>
          <h3><%- ph.title %></h3>
          <ul>
            <% ph.items.forEach(function(item) { %>
            <li><%- item %></li>
            <% }); %>
          </ul>
        </div>
        <% }); %>
      </div>
    </section>

    <!-- Ideas -->
    <section class="reveal">
      <div class="section-label" data-content-path="conversation-2.ideas.label"><%- content.ideas.label %></div>
      <h2 class="section-heading" data-content-path="conversation-2.ideas.heading"><%- content.ideas.heading %></h2>
      <div class="ideas-grid">
        <% content.ideas.items.forEach(function(idea, i) { %>
        <div class="idea-card" data-content-path="conversation-2.ideas.items[<%= i %>]">
          <div class="idea-tag"><%- idea.tag %></div>
          <h3><%- idea.title %></h3>
          <p><%- idea.description %></p>
        </div>
        <% }); %>
      </div>
    </section>

    <!-- Closing Quote -->
    <div class="quote-block reveal" data-content-path="conversation-2.closingQuote">
      <blockquote>&ldquo;<%- content.closingQuote.text %>&rdquo;</blockquote>
      <div class="attribution">&mdash; <strong><%- content.closingQuote.author %></strong></div>
      <div class="context"><%- content.closingQuote.context %></div>
    </div>

    <!-- Next Steps -->
    <section class="reveal">
      <div class="section-label" data-content-path="conversation-2.nextSteps.label"><%- content.nextSteps.label %></div>
      <h2 class="section-heading" data-content-path="conversation-2.nextSteps.heading"><%- content.nextSteps.heading %></h2>
      <div class="next-steps-list">
        <% content.nextSteps.items.forEach(function(item, i) { %>
        <div class="next-step" data-content-path="conversation-2.nextSteps.items[<%= i %>]">
          <div class="check"></div>
          <span><%- item %></span>
        </div>
        <% }); %>
      </div>
    </section>

  </div>

  <footer>
    <p>Workhorse &times; GoDoGood &mdash; <a href="/index.html">Original Conversation</a> &middot; <a href="/process.html">Full System</a></p>
  </footer>

  <button class="back-to-top" id="backToTop" aria-label="Back to top">&uarr;</button>

  <script>
    // Scroll effects
    const nav = document.querySelector('nav');
    const backToTop = document.getElementById('backToTop');
    window.addEventListener('scroll', () => {
      nav.classList.toggle('scrolled', window.scrollY > 20);
      backToTop.classList.toggle('visible', window.scrollY > 400);
    });
    backToTop.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

    // Reveal on scroll
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
  </script>

</body>
</html>
