<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= content.meta.title %></title>
  <meta name="description" content="<%= content.meta.description %>">
  <meta property="og:title" content="<%= content.meta.ogTitle %>">
  <meta property="og:description" content="<%= content.meta.ogDescription %>">
  <meta property="og:type" content="article">
  <meta property="og:image" content="https://images.unsplash.com/photo-1558655146-9f40138edfeb?w=1200&h=630&fit=crop">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= content.meta.ogTitle %>">
  <meta name="twitter:description" content="<%= content.meta.twitterDescription %>">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>◆</text></svg>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #FAFAF8;
      --text: #1A1A1A;
      --text-muted: #6B6B6B;
      --accent: #2C2C2C;
      --accent-light: #F0EFED;
      --border: #E5E4E1;
      --highlight: #E8E6E1;
      --quote-bg: #F5F4F1;
      --nav-height: 56px;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    html {
      scroll-behavior: smooth;
      scroll-padding-top: var(--nav-height);
    }

    body {
      font-family: 'Inter', -apple-system, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
    }

    /* --- Sticky Nav --- */
    nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      background: rgba(250, 250, 248, 0.85);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid transparent;
      height: var(--nav-height);
      transition: border-color 0.3s, box-shadow 0.3s;
    }

    nav.scrolled {
      border-bottom-color: var(--border);
      box-shadow: 0 1px 8px rgba(0,0,0,0.04);
    }

    .nav-inner {
      max-width: 900px;
      margin: 0 auto;
      padding: 0 40px;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .nav-logo {
      font-weight: 700;
      font-size: 14px;
      letter-spacing: -0.01em;
      color: var(--text);
      text-decoration: none;
    }

    .nav-logo span {
      color: var(--text-muted);
      font-weight: 400;
    }

    .nav-links {
      display: flex;
      gap: 4px;
      list-style: none;
    }

    .nav-links a {
      font-size: 13px;
      font-weight: 500;
      color: var(--text-muted);
      text-decoration: none;
      padding: 6px 12px;
      border-radius: 6px;
      transition: color 0.2s, background 0.2s;
    }

    .nav-links a:hover {
      color: var(--text);
      background: var(--accent-light);
    }

    .nav-links a.active {
      color: var(--text);
      background: var(--accent-light);
    }

    .nav-toggle {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      padding: 8px;
      color: var(--text);
    }

    .nav-toggle svg {
      width: 20px;
      height: 20px;
      display: block;
    }

    /* --- Header --- */
    header {
      padding: calc(var(--nav-height) + 60px) 40px 60px;
      max-width: 900px;
      margin: 0 auto;
    }

    header .meta {
      font-size: 13px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 24px;
    }

    header h1 {
      font-family: 'Fraunces', Georgia, serif;
      font-size: clamp(32px, 5vw, 52px);
      font-weight: 700;
      line-height: 1.15;
      letter-spacing: -0.02em;
      margin-bottom: 20px;
    }

    header .subtitle {
      font-size: 18px;
      color: var(--text-muted);
      max-width: 620px;
      line-height: 1.6;
    }

    .header-cta {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-top: 24px;
      padding: 12px 24px;
      background: var(--accent);
      color: white;
      text-decoration: none;
      font-size: 14px;
      font-weight: 600;
      border-radius: 8px;
      transition: background 0.2s, transform 0.2s;
    }

    .header-cta:hover {
      background: #444;
      transform: translateY(-1px);
    }

    .header-cta svg {
      width: 16px;
      height: 16px;
    }

    /* --- Sections --- */
    section {
      max-width: 900px;
      margin: 0 auto;
      padding: 0 40px;
    }

    .section-block {
      padding: 60px 0;
      border-top: 1px solid var(--border);
    }

    .section-label {
      font-size: 11px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-muted);
      margin-bottom: 16px;
      font-weight: 500;
    }

    h2 {
      font-family: 'Fraunces', Georgia, serif;
      font-size: 28px;
      font-weight: 600;
      margin-bottom: 20px;
      line-height: 1.3;
    }

    p {
      font-size: 16px;
      margin-bottom: 16px;
      color: var(--text);
    }

    p.muted {
      color: var(--text-muted);
    }

    /* --- Quote Blocks --- */
    .quote-block {
      background: var(--quote-bg);
      border-left: 3px solid var(--accent);
      padding: 24px 28px;
      margin: 28px 0;
      border-radius: 0 8px 8px 0;
    }

    .quote-block .quote-text {
      font-family: 'Fraunces', Georgia, serif;
      font-size: 19px;
      line-height: 1.5;
      font-weight: 400;
      margin-bottom: 10px;
    }

    .quote-block .quote-attr {
      font-size: 13px;
      color: var(--text-muted);
      font-weight: 500;
    }

    /* --- Theme Cards --- */
    .themes-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 20px;
      margin-top: 28px;
    }

    .theme-card {
      background: white;
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 28px;
      transition: transform 0.2s, box-shadow 0.2s;
    }

    .theme-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 16px rgba(0,0,0,0.06);
    }

    .theme-card .theme-num {
      font-size: 12px;
      font-weight: 600;
      color: var(--text-muted);
      letter-spacing: 0.06em;
      margin-bottom: 10px;
    }

    .theme-card h3 {
      font-family: 'Fraunces', Georgia, serif;
      font-size: 20px;
      font-weight: 600;
      margin-bottom: 10px;
    }

    .theme-card p {
      font-size: 14px;
      color: var(--text-muted);
      line-height: 1.6;
      margin-bottom: 0;
    }

    /* --- Process Steps --- */
    .process-steps {
      margin-top: 28px;
    }

    .step {
      display: flex;
      gap: 24px;
      padding: 24px 0;
      border-bottom: 1px solid var(--border);
    }

    .step:last-child { border-bottom: none; }

    .step-num {
      flex-shrink: 0;
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: var(--accent);
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      font-weight: 600;
      margin-top: 2px;
    }

    .step-content h3 {
      font-size: 17px;
      font-weight: 600;
      margin-bottom: 6px;
    }

    .step-content p {
      font-size: 14px;
      color: var(--text-muted);
      margin-bottom: 0;
    }

    /* --- Stats Row --- */
    .stats-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px;
      margin: 28px 0;
    }

    .stat {
      background: white;
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 24px;
      text-align: center;
      transition: transform 0.2s, box-shadow 0.2s;
    }

    .stat:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 16px rgba(0,0,0,0.06);
    }

    .stat .number {
      font-family: 'Fraunces', Georgia, serif;
      font-size: 36px;
      font-weight: 700;
      margin-bottom: 6px;
    }

    .stat .label {
      font-size: 13px;
      color: var(--text-muted);
      line-height: 1.4;
    }

    /* --- Comparison Table --- */
    .comparison {
      margin: 28px 0;
      overflow-x: auto;
    }

    .comparison table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
    }

    .comparison th {
      text-align: left;
      padding: 14px 16px;
      background: var(--accent);
      color: white;
      font-weight: 500;
      font-size: 13px;
      letter-spacing: 0.04em;
    }

    .comparison th:first-child { border-radius: 8px 0 0 0; }
    .comparison th:last-child { border-radius: 0 8px 0 0; }

    .comparison td {
      padding: 14px 16px;
      border-bottom: 1px solid var(--border);
    }

    .comparison tr:last-child td { border-bottom: none; }

    .comparison tr:nth-child(even) td {
      background: var(--accent-light);
    }

    /* --- CTA / Next Steps --- */
    .next-steps {
      background: var(--accent);
      color: white;
      border-radius: 12px;
      padding: 40px;
      margin: 28px 0;
    }

    .next-steps h3 {
      font-family: 'Fraunces', Georgia, serif;
      font-size: 22px;
      margin-bottom: 16px;
    }

    .next-steps p {
      color: rgba(255,255,255,0.8);
      font-size: 15px;
      margin-bottom: 12px;
    }

    .next-steps ul {
      list-style: none;
      padding: 0;
    }

    .next-steps li {
      padding: 8px 0;
      padding-left: 20px;
      position: relative;
      color: rgba(255,255,255,0.85);
      font-size: 15px;
    }

    .next-steps li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 16px;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: rgba(255,255,255,0.4);
    }

    /* --- Scroll Animations --- */
    .reveal {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* Stagger children */
    .theme-card.reveal,
    .stat.reveal,
    .step.reveal {
      transition-delay: calc(var(--i, 0) * 0.08s);
    }

    /* --- Back to Top --- */
    .back-to-top {
      position: fixed;
      bottom: 32px;
      right: 32px;
      width: 42px;
      height: 42px;
      border-radius: 50%;
      background: var(--accent);
      color: white;
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transform: translateY(10px);
      transition: opacity 0.3s, transform 0.3s;
      pointer-events: none;
      box-shadow: 0 2px 12px rgba(0,0,0,0.15);
    }

    .back-to-top.visible {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }

    .back-to-top:hover {
      background: #444;
    }

    .back-to-top svg {
      width: 18px;
      height: 18px;
    }

    /* --- Footer --- */
    footer {
      max-width: 900px;
      margin: 0 auto;
      padding: 40px 40px 80px;
      border-top: 1px solid var(--border);
      font-size: 13px;
      color: var(--text-muted);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    footer a {
      color: var(--text);
      text-decoration: none;
      font-weight: 500;
    }

    /* --- Mobile --- */
    @media (max-width: 720px) {
      .nav-inner { padding: 0 24px; }

      .nav-links {
        display: none;
        position: absolute;
        top: var(--nav-height);
        left: 0;
        right: 0;
        background: rgba(250, 250, 248, 0.97);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        flex-direction: column;
        padding: 12px 24px 20px;
        border-bottom: 1px solid var(--border);
        gap: 0;
      }

      .nav-links.open { display: flex; }

      .nav-links a {
        padding: 10px 12px;
        font-size: 15px;
      }

      .nav-toggle { display: block; }

      header, section, footer { padding-left: 24px; padding-right: 24px; }
      .themes-grid { grid-template-columns: 1fr; }
      .stats-row { grid-template-columns: 1fr; }
      .step { flex-direction: column; gap: 12px; }
      footer { flex-direction: column; gap: 12px; text-align: center; }
    }
    </style>
</head>
<body>

  <%- include('partials/nav', { page, site }) %>

  <header id="top">
    <div class="meta reveal" data-content-path="index.header.dateline"><%- content.header.dateline %></div>
    <h1 class="reveal" data-content-path="index.header.title"><%- content.header.title %></h1>
    <p class="subtitle reveal" data-content-path="index.header.subtitle"><%- content.header.subtitle %></p>
    <a href="<%- content.header.ctaHref %>" class="header-cta reveal" data-content-path="index.header.ctaText"><%- content.header.ctaText %> <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
  </header>

  <section id="premise">
    <div class="section-block">
      <div class="section-label reveal"><%- content.premise.label %></div>
      <h2 class="reveal" data-content-path="index.premise.heading"><%- content.premise.heading %></h2>
<% content.premise.paragraphs.forEach((p, i) => { %>
      <p class="reveal" data-content-path="index.premise.paragraphs[<%= i %>]"><%- p %></p>
<% }) %>
      <div class="quote-block reveal">
        <div class="quote-text" data-content-path="index.premise.quote.text">&ldquo;<%- content.premise.quote.text %>&rdquo;</div>
        <div class="quote-attr" data-content-path="index.premise.quote.attribution">&mdash; <%- content.premise.quote.attribution %></div>
      </div>
    </div>
  </section>

  <section id="themes">
    <div class="section-block">
      <div class="section-label reveal"><%- content.themes.label %></div>
      <h2 class="reveal" data-content-path="index.themes.heading"><%- content.themes.heading %></h2>
      <div class="themes-grid">
<% content.themes.cards.forEach((card, i) => { %>
        <div class="theme-card reveal" style="--i:<%= i %>">
          <div class="theme-num"><%- card.number %></div>
          <h3 data-content-path="index.themes.cards[<%= i %>].title"><%- card.title %></h3>
          <p data-content-path="index.themes.cards[<%= i %>].description"><%- card.description %></p>
        </div>
<% }) %>
      </div>
    </div>
  </section>

  <section id="quotes">
    <div class="section-block">
      <div class="section-label reveal"><%- content.quotes.label %></div>
      <h2 class="reveal" data-content-path="index.quotes.heading"><%- content.quotes.heading %></h2>
<% content.quotes.items.forEach((q, i) => { %>
      <div class="quote-block reveal">
        <div class="quote-text" data-content-path="index.quotes.items[<%= i %>].text">&ldquo;<%- q.text %>&rdquo;</div>
        <div class="quote-attr" data-content-path="index.quotes.items[<%= i %>].attribution">&mdash; <%- q.attribution %></div>
      </div>
<% }) %>
    </div>
  </section>

  <section id="process">
    <div class="section-block">
      <div class="section-label reveal"><%- content.process.label %></div>
      <h2 class="reveal" data-content-path="index.process.heading"><%- content.process.heading %></h2>
      <p class="muted reveal" data-content-path="index.process.intro"><%- content.process.intro %></p>
      <div class="process-steps">
<% content.process.steps.forEach((step, i) => { %>
        <div class="step reveal" style="--i:<%= i %>">
          <div class="step-num"><%= i + 1 %></div>
          <div class="step-content">
            <h3 data-content-path="index.process.steps[<%= i %>].title"><%- step.title %></h3>
            <p data-content-path="index.process.steps[<%= i %>].description"><%- step.description %></p>
          </div>
        </div>
<% }) %>
      </div>
    </div>
  </section>

  <section id="comparison">
    <div class="section-block">
      <div class="section-label reveal"><%- content.comparison.label %></div>
      <h2 class="reveal" data-content-path="index.comparison.heading"><%- content.comparison.heading %></h2>
      <div class="comparison reveal">
        <table>
          <thead>
            <tr>
<% content.comparison.columns.forEach(col => { %>
              <th><%- col %></th>
<% }) %>
            </tr>
          </thead>
          <tbody>
<% content.comparison.rows.forEach((row, i) => { %>
            <tr>
              <td><strong><%- row[0] %></strong></td>
              <td data-content-path="index.comparison.rows[<%= i %>][1]"><%- row[1] %></td>
              <td data-content-path="index.comparison.rows[<%= i %>][2]"><%- row[2] %></td>
            </tr>
<% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section id="numbers">
    <div class="section-block">
      <div class="section-label reveal"><%- content.numbers.label %></div>
      <h2 class="reveal" data-content-path="index.numbers.heading"><%- content.numbers.heading %></h2>
      <div class="stats-row">
<% content.numbers.stats.forEach((stat, i) => { %>
        <div class="stat reveal" style="--i:<%= i %>">
          <div class="number" data-content-path="index.numbers.stats[<%= i %>].value"><%- stat.value %></div>
          <div class="label" data-content-path="index.numbers.stats[<%= i %>].label"><%- stat.label %></div>
        </div>
<% }) %>
      </div>
    </div>
  </section>

  <section id="opportunity">
    <div class="section-block">
      <div class="section-label reveal"><%- content.opportunity.label %></div>
      <h2 class="reveal" data-content-path="index.opportunity.heading"><%- content.opportunity.heading %></h2>
<% content.opportunity.paragraphs.forEach((p, i) => { %>
      <p class="reveal" data-content-path="index.opportunity.paragraphs[<%= i %>]"><%- p %></p>
<% }) %>
      <div class="next-steps reveal">
        <h3 data-content-path="index.opportunity.nextSteps.title"><%- content.opportunity.nextSteps.title %></h3>
        <ul>
<% content.opportunity.nextSteps.items.forEach((item, i) => { %>
          <li data-content-path="index.opportunity.nextSteps.items[<%= i %>]"><%- item %></li>
<% }) %>
        </ul>
      </div>
    </div>
  </section>

  <section id="stack">
    <div class="section-block">
      <div class="section-label reveal"><%- content.stack.label %></div>
      <h2 class="reveal" data-content-path="index.stack.heading"><%- content.stack.heading %></h2>
      <p class="muted reveal" data-content-path="index.stack.intro"><%- content.stack.intro %></p>
      <div class="themes-grid">
<% content.stack.cards.forEach((card, i) => { %>
        <div class="theme-card reveal" style="--i:<%= i %>">
          <h3 data-content-path="index.stack.cards[<%= i %>].title"><%- card.title %></h3>
          <p data-content-path="index.stack.cards[<%= i %>].description"><%- card.description %></p>
        </div>
<% }) %>
      </div>
    </div>
  </section>

  <%- include('partials/footer', { page, site, content }) %>

  <button class="back-to-top" id="backToTop" aria-label="Back to top">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
  </button>

  <script>
    // --- Scroll-spy: highlight active nav link ---
    const sections = document.querySelectorAll('section[id]');
    const navLinks = document.querySelectorAll('.nav-links a');
    const navbar = document.getElementById('navbar');
    const backToTop = document.getElementById('backToTop');

    function updateScrollSpy() {
      const scrollY = window.scrollY + 120;

      sections.forEach(section => {
        const top = section.offsetTop;
        const height = section.offsetHeight;
        const id = section.getAttribute('id');

        if (scrollY >= top && scrollY < top + height) {
          navLinks.forEach(link => {
            link.classList.remove('active');
            if (link.getAttribute('href') === '#' + id) {
              link.classList.add('active');
            }
          });
        }
      });

      // Nav shadow
      navbar.classList.toggle('scrolled', window.scrollY > 20);

      // Back to top
      backToTop.classList.toggle('visible', window.scrollY > 500);
    }

    window.addEventListener('scroll', updateScrollSpy, { passive: true });
    updateScrollSpy();

    // --- Back to top ---
    backToTop.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    // --- Mobile nav toggle ---
    const navToggle = document.getElementById('navToggle');
    const navLinksEl = document.getElementById('navLinks');

    navToggle.addEventListener('click', () => {
      navLinksEl.classList.toggle('open');
    });

    // Close mobile nav on link click
    navLinksEl.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        navLinksEl.classList.remove('open');
      });
    });

    // --- Scroll reveal animations ---
    const revealElements = document.querySelectorAll('.reveal');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.1,
      rootMargin: '0px 0px -40px 0px'
    });

    revealElements.forEach(el => observer.observe(el));
    </script>

</body>
</html>